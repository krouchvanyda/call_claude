# ===========================================================================
# Copy to .env and edit before running. Generate APP_KEY with:
#   php artisan key:generate
# Required production swaps marked with [REQUIRED].
# ===========================================================================

APP_NAME=ERP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Server ---
# The original SERVER_CONTEXT_PATH=/ ; Laravel serves at the web root.

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=erp
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Cache / Queue / Session ---
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# --- JWT [REQUIRED in non-local environments] ---
# Generate a long random secret (>= 64 chars). Example:
#   openssl rand -base64 64
JWT_ISSUER=erp
JWT_SECRET=dev-secret-change-me-in-production-must-be-long-enough-for-hmac-sha256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# --- CORS ---
# Comma-separated list, e.g. https://app.example.com,https://admin.example.com
CORS_ALLOWED_HOSTS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# --- Cache / Redis (presence state + STOMP fan-out pub/sub) ---
# CACHE_DRIVER=redis is set above. Redis also carries the STOMP broadcast frames.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Realtime: STOMP-over-WebSocket (Spring SimpleBroker replacement) ---
# The stomp server (php artisan erp:stomp-serve) is reached via nginx at /ws.
STOMP_REDIS_CHANNEL=erp.stomp
STOMP_PORT=8090

# --- Stream Video (server-side token mint) ---
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_TOKEN_TTL_MINUTES=60

# --- Firebase Cloud Messaging (incoming-call push) ---
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_JSON_PATH=/secrets/firebase-sa.json

# --- Chat / call signalling ---
CHAT_CALL_RING_TIMEOUT_SECONDS=60
CHAT_CALL_ACCEPT_GRACE_SECONDS=5
CHAT_CALL_SWEEP_INTERVAL_MS=5000

# --- Uploads (employee avatars) ---
UPLOAD_AVATAR_DIR=./uploads/avatars
UPLOAD_AVATAR_PUBLIC_BASE_URL=/uploads/avatars
UPLOAD_AVATAR_MAX_SIZE=5242880
UPLOAD_AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp
